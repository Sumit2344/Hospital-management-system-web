PORT=5000
MONGO_URI=<paste-your-mongodb-atlas-uri-here>

FRONTEND_URL_ONE=https://your-frontend.vercel.app
FRONTEND_URL_TWO=https://your-dashboard.vercel.app

NODE_ENV=development

JWT_SECRET=<replace-with-a-long-random-secret>

CLOUDINARY_CLOUD_NAME=<cloudinary-cloud-name>
CLOUDINARY_API_KEY=<cloudinary-api-key>
CLOUDINARY_API_SECRET=<cloudinary-api-secret>

RAZORPAY_KEY_ID=<razorpay-key-id>
RAZORPAY_KEY_SECRET=<razorpay-key-secret>

BACKEND_URL=http://localhost:5000
OAUTH_SUCCESS_REDIRECT=http://localhost:5173

GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/user/oauth/google/callback

GITHUB_CLIENT_ID=<github-client-id>
GITHUB_CLIENT_SECRET=<github-client-secret>
GITHUB_REDIRECT_URI=http://localhost:5000/api/v1/user/oauth/github/callback
